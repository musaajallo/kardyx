{
  "$schema": "https://schemas.styledictionary.dev/v4/style-dictionary.json",
  "$description": "Kardyx Brand v1 design tokens — Atlas × Quiet Game hybrid. Source of truth for Tailwind (web), NativeWind (mobile), and Figma variables.",
  "color": {
    "ground": {
      "paper":      { "$value": "#FAF6EC", "$description": "Default page background — the ground of every surface" },
      "paper-deep": { "$value": "#F2EDE0", "$description": "Inset surfaces, cards, secondary panels" },
      "mist":       { "$value": "#E8E2D4", "$description": "Quiet dividers, disabled states, soft fills" }
    },
    "ink": {
      "soft":       { "$value": "#3A332A", "$description": "Body text, secondary headings" },
      "default":    { "$value": "#1A1714", "$description": "Primary text, headlines, dark surfaces" },
      "slate":      { "$value": "#6B7280", "$description": "System metadata, timestamps" }
    },
    "accent": {
      "ochre":      { "$value": "#C18A4A", "$description": "Soft accent — brand divider, marks, passive states" },
      "clay":       { "$value": "#C04A1A", "$description": "High-energy accent — Power-Up triggers, primary CTA" },
      "clay-deep":  { "$value": "#8C3210", "$description": "Hover/pressed state for clay; emphasis in editorial italic" }
    },
    "semantic": {
      "verdigris":  { "$value": "#2A5550", "$description": "Reserved — saved / persisted / synced states only" }
    }
  },
  "font": {
    "family": {
      "display":    { "$value": "Newsreader, ui-serif, Georgia, serif" },
      "body":       { "$value": "Newsreader, ui-serif, Georgia, serif" },
      "ui":         { "$value": "Inter, ui-sans-serif, system-ui, sans-serif" },
      "mono":       { "$value": "JetBrains Mono, ui-monospace, monospace" }
    },
    "weight": {
      "light":      { "$value": "300" },
      "regular":    { "$value": "400" },
      "medium":     { "$value": "500" },
      "semibold":   { "$value": "600" },
      "bold":       { "$value": "700" }
    },
    "size": {
      "xs":         { "$value": "11px" },
      "sm":         { "$value": "13px" },
      "base":       { "$value": "15px" },
      "lg":         { "$value": "18px" },
      "xl":         { "$value": "22px" },
      "2xl":        { "$value": "28px" },
      "3xl":        { "$value": "36px" },
      "4xl":        { "$value": "48px" },
      "display":    { "$value": "60px" },
      "hero":       { "$value": "96px" }
    },
    "letter-spacing": {
      "tight":      { "$value": "-0.025em" },
      "normal":     { "$value": "0" },
      "wide":       { "$value": "0.05em" },
      "mono":       { "$value": "0.04em" },
      "uppercase":  { "$value": "0.20em" }
    }
  },
  "space": {
    "0":  { "$value": "0px" },
    "1":  { "$value": "4px" },
    "2":  { "$value": "8px" },
    "3":  { "$value": "12px" },
    "4":  { "$value": "16px" },
    "5":  { "$value": "20px" },
    "6":  { "$value": "24px" },
    "8":  { "$value": "32px" },
    "10": { "$value": "40px" },
    "12": { "$value": "48px" },
    "16": { "$value": "64px" },
    "20": { "$value": "80px" },
    "24": { "$value": "96px" },
    "32": { "$value": "128px" }
  },
  "radius": {
    "none":  { "$value": "0px" },
    "sm":    { "$value": "4px" },
    "md":    { "$value": "6px" },
    "lg":    { "$value": "8px" },
    "xl":    { "$value": "14px" },
    "card":  { "$value": "22px" },
    "phone": { "$value": "32px" },
    "full":  { "$value": "999px" }
  },
  "motion": {
    "duration": {
      "instant":   { "$value": "120ms" },
      "card":      { "$value": "320ms" },
      "powerup":   { "$value": "480ms" },
      "round":     { "$value": "600ms" }
    },
    "easing": {
      "settle-stamp": { "$value": "cubic-bezier(0.22, 0.6, 0.2, 1)", "$description": "Default — settle then commit. No bounce." },
      "micro":        { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$description": "Micro-interactions: button press, focus" }
    }
  },
  "border": {
    "hairline": { "$value": "1px solid rgba(26, 23, 20, 0.10)" },
    "soft":     { "$value": "1px solid rgba(26, 23, 20, 0.05)" }
  }
}
